rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() { return request.auth != null; }
    function isAdmin() { 
      return isSignedIn() && 
        (request.auth.token.email.matches('.*@decentralizedmasters\\.com') && request.auth.token.email_verified == true); 
    }
    
    function isValidFormSubmission(data) {
      return data.keys().hasAll(['email', 'timezone', 'franja', 'laptop', 'zoom', 'circle', 'mouseTouchpad', 'windowsMac', 'contactMethods', 'anythingElse', 'createdAt']) &&
             data.email is string &&
             data.timezone is string &&
             data.franja is list &&
             data.laptop is string &&
             data.zoom is string &&
             data.circle is string &&
             data.mouseTouchpad is string &&
             data.windowsMac is string &&
             data.contactMethods is list &&
             data.anythingElse is string;
    }

    match /form_submissions/{submissionId} {
      allow read: if true;
      allow create: if isValidFormSubmission(request.resource.data);
      allow update: if false;
      allow delete: if true;
    }
    match /funnel_tracking/{sessionId} {
      allow read, create, update: if true;
    }
  }
}
