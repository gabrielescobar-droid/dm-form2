rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() { return request.auth != null; }
    function isAdmin() { 
      return isSignedIn() && 
        (request.auth.token.email.matches('.*@decentralizedmasters\\.com') && request.auth.token.email_verified == true); 
    }
    
    function isValidFormSubmission(data) {
      return data.keys().hasAll(['email', 'timezone', 'franja', 'laptop', 'zoom', 'circle', 'mouseTouchpad', 'windowsMac', 'anythingElse', 'createdAt']) &&
             data.keys().size() == 10 &&
             data.email is string && data.email.size() <= 256 &&
             data.timezone is string && data.timezone.size() <= 100 &&
             data.franja is list && data.franja.size() <= 10 && data.franja.size() > 0 && data.franja[0] is string &&
             data.laptop is string && data.laptop.size() <= 100 &&
             data.zoom is string && data.zoom.size() <= 100 &&
             data.circle is string && data.circle.size() <= 100 &&
             data.mouseTouchpad is string && data.mouseTouchpad.size() <= 100 &&
             data.windowsMac is string && data.windowsMac.size() <= 100 &&
             data.anythingElse is string && data.anythingElse.size() <= 2000 &&
             data.createdAt == request.time;
    }

    match /form_submissions/{submissionId} {
      allow read: if true;
      allow create: if isValidFormSubmission(request.resource.data);
      allow update: if false;
      allow delete: if true;
    }
  }
}
